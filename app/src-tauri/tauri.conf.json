{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Otoha",
  "version": "0.1.0",
  "identifier": "com.otoha.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Otoha — Settings",
        "width": 460,
        "height": 480,
        "visible": false,
        "resizable": false,
        "minimizable": false,
        "maximizable": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/OWNER/otoha/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxMTU2QjNCNDZBRTgyMkEKUldRcWdxNUdPMnNWc1RrbWdMT1RIUmtjRTVDUVNGN2o2WWUxMk9pVTkraWd1UFc0SVZhTFUya1oK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "models/kokoro-v1.0.onnx": "models/kokoro-v1.0.onnx",
      "models/voices-v1.0.bin": "models/voices-v1.0.bin",
      "server-dist/otoha-server": "otoha-server"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
